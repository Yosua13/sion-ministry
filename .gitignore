# Ignore OS system files
.DS_Store
Thumbs.db
db.db

# Ignore IDE / Editor configurations
.vscode/
.idea/
*.suo
*.ntvsca*
*.njsproj
*.sln
*.sw?

# Ignore environment variables / secrets
.env
.env.local
.env.*
!.env.example

# Ignore Node.js / Vite build files and dependencies
node_modules/
dist/
dist-ssr/
.vite/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Ignore Go build binaries and executables
backend/main
backend/server
*.exe
*.exe~
*.dll
*.so
*.dylib

# Allow .antigravity directory to be tracked/included
.antigravity/

# But ignore large system logs inside .antigravity to keep the git repository lightweight
.antigravity/brain/**/logs/
.antigravity/brain/**/scratch/
.antigravity/brain/**/*.log

